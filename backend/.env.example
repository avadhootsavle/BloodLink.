HOST=0.0.0.0
PORT=4000

# MongoDB Atlas connection string
# Replace:
# - <db_username> with your Atlas database username
# - <db_password> with your Atlas database password
# - <db_name> with your database name, for example bloodlink
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.wb8b1d0.mongodb.net/<db_name>?retryWrites=true&w=majority&appName=Cluster0

# SMTP config for sending donor emails
# For Gmail:
# - EMAIL_HOST should be smtp.gmail.com
# - EMAIL_PORT should be 587
# - EMAIL_USER should be your Gmail address
# - EMAIL_PASS should be a Gmail App Password, not your normal Gmail password
# - EMAIL_FROM is the sender email shown to recipients
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com
